{
	"appId": "com.roadrobos.app",
	"appName": "RoAdRoBo's",
	"webDir": "dist",
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 2000,
			"launchAutoHide": true,
			"backgroundColor": "#ffffff",
			"androidSplashResourceName": "splash",
			"androidScaleType": "CENTER_CROP",
